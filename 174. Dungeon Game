class Solution {
    public int calculateMinimumHP(int[][] dungeon) {

        int m = dungeon.length;
        int n = dungeon[0].length;

        int[][] arr = new int[m][n];

        arr[m-1][n-1] = Math.max(1 - dungeon[m-1][n-1], 1);

        for(int i=m-2;i>=0;i--)
        {
            arr[i][n-1] = arr[i+1][n-1]-dungeon[i][n-1]>0?arr[i+1][n-1]-dungeon[i][n-1]:1;        
        }

        for(int j=n-2;j>=0;j--)
        {
            arr[m-1][j] = arr[m-1][j+1]-dungeon[m-1][j]>0?arr[m-1][j+1]-dungeon[m-1][j]:1;        
        }

        for(int i=m-2;i>=0;i--)
        {
            for(int j=n-2;j>=0;j--)
            {
                arr[i][j] = Math.max(Math.min(arr[i+1][j],arr[i][j+1])-dungeon[i][j],1);
            }
        }
        return arr[0][0];
    }
}
