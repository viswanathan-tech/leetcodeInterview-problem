        int i = 1;
        while(curr!=null)
        {
            if(i==left)
            break;
            prev=curr;
            curr = curr.next;

            System.out.println(prev.val +" "+ curr.val);
            i++;
        }
        i--;
        
        ListNode prev1 = null;
        ListNode curr1 = curr;
        while(curr1!=null)
        {
            

            if(i==right)
            break;
            next = curr1.next;
            curr1.next = prev1;
            prev1 = curr1;
            curr1 = next;
            i++;
            
        }
        if(prev!=null)
        prev.next = prev1;
        curr.next = curr1;
        return head;
        

        
