class Solution {
    public boolean isMatch(String s, String p) {
        int m = s.length()+1;
        int n = p.length()+1;
        boolean[][] matrix = new boolean[m][n];
        //empty string and empty pattern are true
        matrix[0][0] = true;
        for(int i=1;i<m;i++)
        {
            matrix[i][0] = false;
        }
        for(int j=1;j<n;j++)
        {
            char pChar = p.charAt(j-1);
            if(pChar=='*')
            {
                if(matrix[0][j-2]==true)
                {
                    matrix[0][j] = true;
                }

            }
            else
            {
                matrix[0][j] = false;
            }
            
        }
        for (int i = 1; i < m; i++) {
            for (int j = 1; j < n; j++) {

                char sChar = s.charAt(i - 1);
                char pChar = p.charAt(j - 1);

                if (pChar == sChar || pChar == '.') {
                    matrix[i][j] = matrix[i - 1][j - 1];
                } 
                else if (pChar == '*') {
                    // zero occurrence
                    matrix[i][j] = matrix[i][j - 2];

                    // one or more occurrence
                    char prev = p.charAt(j - 2);
                    if (prev == sChar || prev == '.') 
                    {
                        matrix[i][j] |= matrix[i - 1][j];
                    }
                }
            }
        }

        for (int i = 0; i < matrix.length; i++) {
            for (int j = 0; j < matrix[i].length; j++) {
                System.out.print(matrix[i][j] + " ");
            }
            System.out.println();
        }
        if(matrix[m-1][n-1]==true)
        return true;
        else
        return false;
    }
}
